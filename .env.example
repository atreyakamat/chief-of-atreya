# ==========================================
# ZEN AGENT CONFIGURATION (Multi-Agent Setup)
# ==========================================

# 1. AI Intelligence Core
# Recommended: 'groq' for blazing speed, or 'openrouter' for model variety.
AI_PROVIDER=groq

# ------------------------------------------
# Cloud Provider Keys (Uncomment the one you use)
# ------------------------------------------
# Groq (Fastest for Supervisor logic)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# OpenRouter (Great for access to GPT-4o, Claude, or free models)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# NVIDIA NIM (Meta/Llama optimizations)
# NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA_MODEL=meta/llama3-70b-instruct

# Qwen/DashScope
# QWEN_API_KEY=your_qwen_api_key_here
# QWEN_MODEL=qwen-plus

# Ollama (Local Fallback for Privacy)
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://127.0.0.1:11434

# ------------------------------------------
# 2. Integration Keys (Zen only activates modules with keys)
# ------------------------------------------

# WhatsApp Web
ENABLE_WHATSAPP=true

# GitHub (For PRD and Code syncing)
GITHUB_TOKEN=your_github_personal_access_token

# Discord (For Project Health Monitoring)
DISCORD_TOKEN=your_discord_bot_token

# Reddit (For Sub-Agent Research)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password

# Email Sync (IMAP) & Send (SMTP)
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Smart Home / IoT
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token

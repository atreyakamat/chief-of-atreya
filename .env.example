# ==========================================
# ZEN AGENT CONFIGURATION (100% Free Setup)
# ==========================================

# 1. AI Intelligence Core
# To keep this 100% FREE, we recommend 'openrouter' (they have a completely free tier) 
# or 'groq' (they have a generous free tier for developers).
AI_PROVIDER=openrouter

# ------------------------------------------
# 100% Free Cloud Provider Keys
# ------------------------------------------
# OpenRouter (Highly Recommended for 100% Free usage)
# Go to openrouter.ai, create a free account, and get a key.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# This is a highly capable Llama 3 8B model that OpenRouter provides completely for FREE:
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
# Another great free option on OpenRouter:
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Groq (Generous Free Tier, Blazing Fast)
# Go to console.groq.com to get a free key.
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama3-8b-8192

# Ollama (100% Free & Local - Requires VRAM/RAM)
# Only use this if your PC isn't gaming, as it uses your hardware.
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://127.0.0.1:11434

# ------------------------------------------
# 2. Integration Keys (All of these integrations are 100% FREE)
# ------------------------------------------

# WhatsApp Web (Free via local browser instance)
ENABLE_WHATSAPP=true

# GitHub (Free Personal Access Token)
# Go to github.com -> Settings -> Developer Settings -> Personal access tokens
GITHUB_TOKEN=your_github_personal_access_token

# Discord (Free Bot Token)
# Go to discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Reddit (Free API Credentials)
# Go to reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password

# Email Sync (Free standard IMAP/SMTP)
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Smart Home / IoT
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token
